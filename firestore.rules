rules_version = '2';

// 2026-05-19: 광범위 개방 (개발/디버깅용). 출시 전에 좁힐 것.
// 전 단계의 strict 룰이 read/write를 막는지 검증 중 — 일단 모든 접근 허용해서
// 연결 자체 문제인지 룰 문제인지 분리한다.
//
// TODO: 출시 전 다음으로 복귀:
//   - 60자 한도 검증
//   - 톤 스키마 검증 (font in ['mono','gothic','myeongjo','song'] 등)
//   - 클라이언트 update/delete 금지
//   - 가능하면 App Check + Cloud Functions로 rate limit
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
